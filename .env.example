# Copy to .env and customise:
#   cp .env.example .env

# Required: random secret key for SearXNG
# Generate with: openssl rand -hex 32
SEARXNG_SECRET_KEY=change-me-to-a-random-secret

# Default search language (en, de, fr, ...)
SEARXNG_DEFAULT_LANG=en

# Transport for the MCP server: "http" (default, exposed on :3333) or "stdio".
# For stdio, run: docker exec -i dao-searxng-mcp node index.js
MCP_TRANSPORT=http

# --- Reliability tuning (all optional; defaults shown) ---------------------

# Timeout for the SearXNG query itself.
# SEARXNG_TIMEOUT_MS=15000

# Per-URL fetch timeout when extracting page content for the top results.
# Lower values bail out faster on hung sites at the cost of occasional misses.
# FETCH_URL_TIMEOUT_MS=8000

# Hard wall-clock budget for a single search tool call. On overrun, still-
# running URL fetches are aborted and surface as fetchError: "budget exceeded";
# fetches that already completed are returned. Should be a few seconds below
# the MCP client's request timeout.
# TOOL_BUDGET_MS=25000

# Hard cap on the tool response length in characters. Tail result blocks are
# dropped first; the Sources list and citation instruction are always kept.
# MAX_OUTPUT_CHARS=20000

# Set to "false" to suppress the deprecated tool aliases (cited_search,
# cited_news_search, cited_science_search). The new names are web_search,
# news_search, science_search.
# EXPOSE_LEGACY_TOOL_NAMES=true
