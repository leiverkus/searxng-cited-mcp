# Copy to .env and customise:
#   cp .env.example .env

# Required: random secret key for SearXNG
# Generate with: openssl rand -hex 32
SEARXNG_SECRET_KEY=change-me-to-a-random-secret

# Default search language (en, de, fr, ...)
SEARXNG_DEFAULT_LANG=en

# Transport for the MCP server: "http" (default, exposed on :3333) or "stdio".
# For stdio, run: docker exec -i searxng-cited-mcp node index.js
MCP_TRANSPORT=http
